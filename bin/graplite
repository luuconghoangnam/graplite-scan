#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH=$(readlink -f "${BASH_SOURCE[0]}")
ROOT=$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)
FIRST="${1:-}"

print_help() {
  cat <<'EOF'
Usage:
  graplite                   # analyze current repo -> MAP.md + IMPACT.md
  graplite scan              # same as above
  graplite .                 # same as above
  graplite /path/to/repo     # analyze target repo -> MAP.md + IMPACT.md
  graplite analyze [repo]
  graplite project [repo]
  graplite agent [repo]
  graplite init              # create .graplite.json in current repo
  graplite init --write-runner --write-gitignore
  graplite doctor
  graplite install
  graplite help
EOF
}

# Smooth default:
#   graplite
#   graplite .
#   graplite /path/to/repo
# all mean: analyze with full short-name outputs (MAP.md + IMPACT.md)
if [[ -z "$FIRST" ]]; then
  exec python3 "$ROOT/tools/graplite_scan.py" --repo . --mode short
fi

case "$FIRST" in
  scan|analyze)
    shift || true
    REPO="${1:-.}"
    shift || true
    exec python3 "$ROOT/tools/graplite_scan.py" --repo "$REPO" --mode short "$@"
    ;;
  project)
    shift || true
    REPO="${1:-.}"
    shift || true
    exec python3 "$ROOT/tools/graplite_scan.py" --repo "$REPO" --mode project "$@"
    ;;
  agent)
    shift || true
    REPO="${1:-.}"
    shift || true
    exec python3 "$ROOT/tools/graplite_scan.py" --repo "$REPO" --mode agent-claude "$@"
    ;;
  init)
    shift || true
    exec python3 "$ROOT/tools/graplite_init.py" "$@"
    ;;
  doctor)
    shift || true
    exec python3 "$ROOT/tools/graplite_doctor.py" "$@"
    ;;
  install)
    shift || true
    exec python3 "$ROOT/tools/graplite_install.py" "$@"
    ;;
  help|-h|--help)
    print_help
    ;;
  *)
    # Treat first arg as repo path for the smoothest UX.
    REPO="$FIRST"
    shift || true
    exec python3 "$ROOT/tools/graplite_scan.py" --repo "$REPO" --mode short "$@"
    ;;
esac
