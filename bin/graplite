#!/usr/bin/env bash
set -euo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
CMD="${1:-analyze}"
shift || true

case "$CMD" in
  analyze)
    REPO="${1:-.}"
    shift || true
    exec python3 "$ROOT/tools/graplite_scan.py" --repo "$REPO" --mode short "$@"
    ;;
  project)
    REPO="${1:-.}"
    shift || true
    exec python3 "$ROOT/tools/graplite_scan.py" --repo "$REPO" --mode project "$@"
    ;;
  agent)
    REPO="${1:-.}"
    shift || true
    exec python3 "$ROOT/tools/graplite_scan.py" --repo "$REPO" --mode agent-claude "$@"
    ;;
  *)
    echo "Usage: $(basename "$0") [analyze|project|agent] [repo-path] [extra args...]" >&2
    exit 1
    ;;
esac
